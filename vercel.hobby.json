{
  "buildCommand": "npm run vercel-build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/sync?mode=rgm",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/alerts?mode=live",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/sync?mode=live",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/sync?mode=scheduler",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/sync?tier=daily",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/sync?tier=weekly",
      "schedule": "0 9 * * 0"
    },
    {
      "path": "/api/cron/sync?mode=bootstrap&rounds=4",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/alerts",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/stats",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/thursday",
      "schedule": "0 14 * * 4"
    }
  ]
}
