{
  "name": "zonning",
  "version": "0.1.0",
  "private": true,
  "overrides": {
    "@hono/node-server": "1.19.13",
    "@swc/helpers": "0.5.23",
    "postcss": "8.5.15"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "vercel-build": "npx tsx scripts/vercel-build.ts",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build",
    "test": "vitest run",
    "db:migrate": "prisma migrate dev",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:sync": "npx tsx scripts/sync-all.ts",
    "db:sync:api": "curl -X POST -H \"Authorization: Bearer %CRON_SECRET%\" http://localhost:3000/api/sync/all",
    "db:sync:watch": "npx tsx scripts/sync-watch.ts",
    "verify:deploy": "npx tsx scripts/verify-deploy.ts",
    "postinstall": "prisma generate",
    "bootstrap:prod": "npx tsx scripts/bootstrap-prod.ts",
    "force-sync": "npx tsx scripts/force-sync-datasets.ts",
    "db:postgis": "npx tsx scripts/apply-postgis.ts",
    "setup:postgres": "npx tsx scripts/setup-postgres.ts",
    "generate-secrets": "npx tsx scripts/generate-secrets.ts",
    "launch-checklist": "npx tsx scripts/launch-checklist.ts",
    "prepare-deploy": "npx tsx scripts/prepare-deploy.ts",
    "finish-deploy": "npx tsx scripts/finish-deploy.ts",
    "auto-finish": "npx tsx scripts/auto-finish.ts",
    "deploy:check": "npm run ci",
    "setup:resend": "npx tsx scripts/setup-resend.ts",
    "agent:env": "npx tsx scripts/agent-env-audit.ts",
    "discover:quebec": "npx tsx scripts/discover-quebec-sources.ts",
    "vercel:plan": "npx tsx scripts/use-vercel-plan.ts",
    "setup:links": "scripts/open-setup-links.bat"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nextjs": "^10.58.0",
    "@stripe/stripe-js": "^9.8.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.21.0",
    "maplibre-gl": "^5.24.0",
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "proj4": "^2.20.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.0.0",
    "stripe": "^22.2.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
