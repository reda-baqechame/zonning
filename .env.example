# Local dev (SQLite)
DATABASE_URL="file:./dev.db"

# Production (Supabase Postgres) — set provider to "postgresql" in prisma/schema.prisma on prod branch
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

SYNC_ENABLED=true
LIVE_SYNC_INTERVAL_MINUTES=5
SYNC_BATCH_SIZE=8

# Enterprise / production (required on Vercel)
CRON_SECRET=change-me-in-production-min-32-chars
SESSION_SECRET=change-me-separate-from-cron-secret

# Ontario expansion (optional)
# EXPAND_ONTARIO=true
# TORONTO_PERMITS_URL=

# Geocoding for PERMIS.AI (set false to disable external geocoders)
# GEOCODE_ENABLED=true
# ICHERCHE_GEOCODE_URL=https://geoegl.msp.gouv.qc.ca/apis/icherche/geocode

# PostGIS spatial queries on Postgres (after npm run db:postgis)
# POSTGIS_ENABLED=true

# City CSV overrides (allowlisted datasets)
# LEVIS_PERMITS_URL=
# BROSSARD_PROJECTS_URL=

ADMIN_EMAILS=demo@zonning.ca

# Upstash Redis (production — distributed rate limits)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Sentry
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=

RESEND_API_KEY=
EMAIL_FROM=ZONNING <alerts@zonning.ca>

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ESSENTIEL=
STRIPE_PRICE_PRO=
STRIPE_PRICE_EQUIPE=
STRIPE_PRICE_CONCIERGE=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

OPENAI_API_KEY=

# Gatineau permits — no Données Québec CKAN yet (see docs/DEPLOY.md)
# GATINEAU_PERMITS_CKAN_ID=permis-de-construction-ville-de-gatineau
# GATINEAU_PERMITS_STATS_URL=

# CASL PDF — set true after external lawyer review
# CASL_LEGAL_REVIEWED=false
