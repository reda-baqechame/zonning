# ZONNING production template — paste into Vercel (Production env)
# Do NOT commit real secrets. Run: npm run generate-secrets

DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

CRON_SECRET=
SESSION_SECRET=

SYNC_ENABLED=true
LIVE_SYNC_INTERVAL_MINUTES=5
SYNC_BATCH_SIZE=8

ADMIN_EMAILS=you@company.com

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Set true only for staging demos — blocked in production by default
# ALLOW_STRIPE_DEMO=true

# Postgres pool size (serverless default 10)
# PG_POOL_MAX=10

RESEND_API_KEY=
EMAIL_FROM=ZONNING <onboarding@resend.dev>

# Optional — app runs in Stripe demo mode until all four are set
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ESSENTIEL=
STRIPE_PRICE_PRO=
STRIPE_PRICE_EQUIPE=
STRIPE_PRICE_CONCIERGE=

# Optional integrations
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
OPENAI_API_KEY=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# City dataset overrides (allowlisted — empty until URLs are set)
# LEVIS_PERMITS_URL=
# LONGUEUIL_PERMITS_URL=
# SHERBROOKE_PERMITS_URL=
# V3R_PERMITS_URL=
# SAGUENAY_PERMITS_URL=
# TERREBONNE_PERMITS_URL=
# REPENTIGNY_PERMITS_URL=
# BROSSARD_PERMITS_URL=
# BROSSARD_PROJECTS_URL=
# SJR_PERMITS_URL=
# DRUMMONDVILLE_PERMITS_URL=
# SAINT_JEROME_PERMITS_URL=
# GRANBY_PERMITS_URL=
# SAINT_HYACINTHE_PERMITS_URL=
# GATINEAU_PERMITS_CKAN_ID=
# GATINEAU_PERMITS_STATS_URL=
# SHERBROOKE_ZONING_URL=
# QUEBEC_ZONING_URL=
# LAVAL_ZONING_URL=
# LONGUEUIL_ZONING_URL=
# AMP_REGISTRY_URL=
# RBQ_INFRACTIONS_URL=
# MTL_INSPECTIONS_URL=
# EXPAND_ONTARIO=true
# TORONTO_PERMITS_URL=

# POSTGIS_ENABLED=true
# CASL_LEGAL_REVIEWED=false
